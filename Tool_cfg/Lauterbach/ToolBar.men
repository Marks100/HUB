MENU.ReProgram
(
	ADD
	TOOLBAR
	(
		TOOLITEM "REFLASH AND DEBUG" "[:flashstate]" ""
		(
			DO stm32f103_flash_and_debug.cmm
		)
		SEPARATOR
		TOOLITEM "FLASH AND RUN" "[:flash]" ""
		(
			DO stm32f103_flash_and_debug.cmm
			Go
		)
		SEPARATOR
		TOOLITEM "RESET CORE" "[:refresh]" ""
		(
			SYStem.down
			SYStem.up
			Go.Direct main
			List.auto
		)
		SEPARATOR
		TOOLITEM "RESET CORE AND RUN" "[:redo]" ""
		(
			SYStem.down
			SYStem.up
			Go
			List.auto
		)
		SEPARATOR
		TOOLITEM "NODEBUG" "[:flashreset]" ""
		(
			SYStem.mode.nodebug
		)
		TOOLITEM "Attach" "[:oinfo]" ""
		(
			SYStem.mode.Attach
		)
		SEPARATOR
		TOOLITEM "Snooper" "[:iview]" ""
		(
			SNOOPer.SELect %Long MODE_MGR_tick_timer_msecs_s
			SNOOPer.Rate 100us
			SNOOPer.SIZE 100000
			SNOOPer.Mode PC
			SNOOPer.Arm
			SNOOPer.state
		)
	)
)	

